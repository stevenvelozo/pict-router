{
    "name": "pict-router",
    "version": "1.0.9",
    "description": "Pict Router",
    "main": "source/Pict-Router.js",
    "scripts": {
        "start": "node source/Pict-Router.js",
        "test": "npx quack test",
        "tests": "npx quack test -g",
        "coverage": "npx quack coverage",
        "build": "npx quack build",
        "test-browser": "npx mocha test/Browser_Integration_tests.js --timeout 60000",
        "lint": "eslint source/**",
        "types": "npx -p typescript tsc -p . --outDir types"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stevenvelozo/pict-router.git"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/stevenvelozo/pict-router/issues"
    },
    "homepage": "https://github.com/stevenvelozo/pict-router#readme",
    "dependencies": {
        "navigo": "^8.11.1",
        "pict-provider": "^1.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.14.0",
        "browser-env": "^3.3.0",
        "eslint": "^9.14.0",
        "jquery": "^3.7.1",
        "pict-docuserve": "^0.1.5",
        "puppeteer": "^24.38.0",
        "quackage": "^1.1.0",
        "typescript": "^5.6.3"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    }
}
